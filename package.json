{
  "name": "ticket-app",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "@cloudflare/workers-types": "^4.20260702.1",
      "hono": "^4.12.27",
      "@orpc/server": "^1.14.6",
      "@orpc/openapi": "^1.14.6",
      "@orpc/zod": "^1.14.6",
      "better-auth": "1.6.23",
      "alchemy": "^0.93.12",
      "lucide-react": "^1.23.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "@orpc/client": "^1.14.6",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:push": "turbo run db:push -F @ticket-app/db",
    "db:studio": "turbo run db:studio -F @ticket-app/db",
    "db:generate": "turbo run db:generate -F @ticket-app/db",
    "db:migrate": "turbo run db:migrate -F @ticket-app/db",
    "deploy": "turbo run deploy -F @ticket-app/infra",
    "destroy": "turbo run destroy -F @ticket-app/infra",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@ticket-app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@ticket-app/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "turbo": "^2.10.2",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.11"
}
