generator client {
  provider = "prisma-client"
  runtime  = "cloudflare"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Enum
// ============================================================

enum SaleMethod {
  FIRST_COME
  LOTTERY
}

enum AdmissionMethod {
  GENERAL_ADMISSION
  NUMBERED_ENTRY
  RESERVED_SEAT
}

enum SeatAllocationMethod {
  NONE
  LOTTERY_LATER
  IMMEDIATE
}

enum InventoryUnitStatus {
  AVAILABLE
  HELD
  SOLD
  DISABLED
}

enum ApplicationStatus {
  APPLIED
  DECIDED
  CANCELED
  EXPIRED
}

enum LotteryMode {
  MANUAL
  AUTO
}

enum LotteryResult {
  PENDING // 当落を出してない
  WON // 当選
  LOST // 落選
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
  EXPIRED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELED
  REFUNDED
  VOIDED
}

enum InventoryHoldStatus {
  ACTIVE
  CONSUMED
  RELEASED
  EXPIRED
}

enum FeePayer {
  // 購入者が負担する
  // 購入者の支払総額に加算される
  // チケット購入画面上に表示される
  BUYER
  // イベント主催者が負担する
  // 購入者の支払総額には影響しない。主催者の精算額から差し引く
  // チケット購入画面には表示されない
  EVENT_ORGANIZER
}

// ============================================================
// 認証
// ============================================================

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name          String
  email         String  @unique
  emailVerified Boolean @default(false) @map("email_verified")
  image         String?

  sessions             Session[]
  accounts             Account[]
  inventoryHolds       InventoryHold[]
  orders               Order[]
  tickets              Ticket[]
  organizerMembers     OrganizerMember[]
  organizerInvitations OrganizerInvitation[]
  applications         Application[]

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expiresAt DateTime @map("expires_at")
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "session_userId_idx")
  @@map("session")
}

model Account {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "account_userId_idx")
  @@map("account")
}

model Verification {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")

  @@index([identifier], map: "verification_identifier_idx")
  @@map("verification")
}

// イベント主催者の情報を管理するテーブル
// 1イベント主催者に複数ユーザーが所属できる
// better-auth の organization テーブルを参考にしている
// @see https://www.better-auth.com/docs/plugins/organization#organization
model Organizer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  name String @unique // 主催者表示名（法人・団体名）
  slug String @unique // 主催者識別子（スラッグ）

  // どの会社に属しているか？
  companyId String

  // ユーザーに表示する問い合わせ先情報
  inquiryEmail       String?
  inquiryPhoneNumber String?

  organizerMembers OrganizerMember[]

  organizerInvitations OrganizerInvitation[]

  organizerFeatures OrganizerFeature[]

  events Event[]

  company Company @relation(fields: [companyId], references: [id])
}

enum OrganizerMemberRole {
  VIEWER
  EDITOR
}

// ユーザーがどのイベント主催者に所属しているかを管理するテーブル
// better-auth の invitation テーブルを参考にしている
// @see https://www.better-auth.com/docs/plugins/organization#member
model OrganizerMember {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  userId      String
  organizerId String
  role        OrganizerMemberRole

  user      User      @relation(fields: [userId], references: [id])
  organizer Organizer @relation(fields: [organizerId], references: [id])

  @@unique([userId, organizerId])
}

// 他のユーザーをイベント主催者として招待する
// better-auth の invitation テーブルを参考にしている
// @see https://www.better-auth.com/docs/plugins/organization#invitation
model OrganizerInvitation {
  // #region better-authで必要なカラム

  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  email       String // このメールアドレスに招待リンクが送られる
  inviterId   String // 招待を行ったユーザーのID
  organizerId String
  role        OrganizerMemberRole
  status      String
  expiresAt   DateTime?

  // #endregion

  organizer     Organizer @relation(fields: [organizerId], references: [id])
  invitedByUser User      @relation(fields: [inviterId], references: [id])
}

// イベント主催者：会社 = 多:1
// 会社情報を管理するテーブル
// 1つの会社が複数のイベント主催者を持つことがあり、その場合1つの会社に対して売上をまとめて振り込むことになる
model Company {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  name String @unique

  organizers         Organizer[]
  companyBankAccount CompanyBankAccount?
  companySettlement  CompanySettlement[]
}

// 会社:銀行口座 = 1:1
// 銀行口座情報を変更する場合は、このテーブルのデータを更新する
// 振り込みが行われた場合、振り込んだ瞬間のデータをログとして別テーブルに保存する
model CompanyBankAccount {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  companyId String @unique

  accountType   BankAccountType
  accountNumber String          @db.Char(7)
  bankName      String
  bankCode      String          @db.Char(4)
  branchName    String
  branchCode    String          @db.Char(3)
  holderName    String

  company Company @relation(fields: [companyId], references: [id])
}

enum BankAccountType {
  ORDINARY // 普通
  CURRENT // 当座
  SAVINGS // 貯蓄
  OTHER // その他
}

// 精算の履歴を管理するテーブル
model CompanySettlement {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String

  // 対象期間
  periodStart DateTime
  periodEnd   DateTime

  transferredAt DateTime? // 実際に振込実行した日時

  // 金額情報
  totalSalesAmount  Int // 売上合計
  feeAmount         Int // 手数料
  transferFeeAmount Int // 振込手数料
  netAmount         Int // 実際の振込額

  // 振込時点の口座情報をスナップショットとして記録する
  accountType   BankAccountType
  accountNumber String          @db.Char(7)
  bankName      String
  bankCode      String          @db.Char(4)
  branchName    String
  branchCode    String          @db.Char(3)
  holderName    String

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, periodStart, periodEnd])
}

// 主催者ごとに使える機能を制御する
model OrganizerFeature {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  organizerId String

  // 機能が割と頻繁に増えるという想定でstring型にしている
  // 増える頻度が低い(3ヶ月に1回くらい)ならenumでいいかもしれない
  key       String
  isEnabled Boolean @default(false)

  organizer Organizer @relation(fields: [organizerId], references: [id])
}

// ============================================================
// イベント・公演
// ============================================================

model Event {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  organizerId String

  name        String
  description String // 何もない場合は空文字

  organizer Organizer @relation(fields: [organizerId], references: [id])

  performances     Performance[]
  saleWindows      SaleWindow[]
  seatCategories   SeatCategory[]
  rateTypes        RateType[]
  voucherTemplates VoucherTemplate[]
  feeRules         FeeRule[]
}

model Performance {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  eventId      String
  venueId      String
  seatLayoutId String? // 整理番号方式の場合はnull、指定席の場合でも未設定段階ではnull

  name        String
  doorsOpenAt DateTime // 開場時間
  startsAt    DateTime // 開始時間

  event      Event       @relation(fields: [eventId], references: [id])
  venue      Venue       @relation(fields: [venueId], references: [id])
  seatLayout SeatLayout? @relation(fields: [seatLayoutId], references: [id])

  inventoryPools     InventoryPool[]
  offerEntitlements  SaleOfferEntitlement[]
  ticketEntitlements TicketEntitlement[]
  inventoryUnits     InventoryUnit[]
  inventoryHoldItems InventoryHoldItem[]
  performanceArtists PerformanceArtist[]
}

model Artist {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  name               String
  imageUrl           String?
  performanceArtists PerformanceArtist[]
}

model PerformanceArtist {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  performanceId String
  artistId      String

  performance Performance @relation(fields: [performanceId], references: [id])
  artist      Artist      @relation(fields: [artistId], references: [id])
}

model Venue {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  name String

  seatLayouts  SeatLayout[]
  performances Performance[]
}

// ============================================================
// 座席のレイアウト
//
// 1つの会場でも、公演ごとに座席レイアウトは変わる
// 1つの会場に対して、複数のレイアウトを登録できるようにする必要がある
// ============================================================

model SeatLayout {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  venueId String
  name    String

  venue Venue @relation(fields: [venueId], references: [id])

  performances Performance[]
  seatZones    SeatZone[]
  seats        Seat[]

  @@unique([venueId, name])
}

// 以下のような階層構造を表現できるように Tree 形式のテーブルを作る
// AREA: スタンド
//   └ AREA: 1塁側
//       └ LEVEL: 200レベル（水平方向の分類）
//           └ SECTION: 24通路
//               └ BLOCK: Aブロック
//                   └ Seat: 18列120番

model SeatZone {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  seatLayoutId String
  parentId     String? // 親の SeatZone がない場合は null になる

  kind  String // area, side, gate, level, block など
  name  String // スタンド, 1塁側, 24通路, 200レベル, Aブロック
  order Int    @default(0)

  seatLayout SeatLayout @relation(fields: [seatLayoutId], references: [id])
  parent     SeatZone?  @relation("SeatZoneTree", fields: [parentId], references: [id])
  children   SeatZone[] @relation("SeatZoneTree")

  seats Seat[]
}

// ============================================================
// 席種
//
// ticketmaster では section -> row -> seat を座席表記の最小単位として保持している
// @see https://developer.ticketmaster.com/products-and-docs/apis/partner/availability/?utm_source=chatgpt.com
// ============================================================

model Seat {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  seatLayoutId String
  seatZoneId   String?

  rowLabel  String? // 18列, C列 など
  seatLabel String // 120番, 8番 など

  seatLayout SeatLayout @relation(fields: [seatLayoutId], references: [id])
  seatZone   SeatZone?  @relation(fields: [seatZoneId], references: [id])

  inventoryUnits InventoryUnit[]

  @@unique([seatLayoutId, rowLabel, seatLabel])
}

// ============================================================
// 席種
//
// ツアーや複数公演で同じ席種を共有するため、席種はEvent配下に置く。
//
// 例: S席, A席, VIP席, 一般席 などなど
// ============================================================

model SeatCategory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  eventId String

  name         String
  description  String // 何もない場合は空文字
  active       Boolean @default(true)
  displayOrder Int     @default(0)

  event Event @relation(fields: [eventId], references: [id])

  inventoryPools InventoryPool[]

  @@unique([eventId, name])
}

// ============================================================
// 料金種別
//
// 大人・子供などの料金区分。
// 実際の価格は SaleWindow(販売受付)や SaleOffer(商品)によって変動するので、
// このテーブルでは持たずに SaleOfferRate に保持する。
//
// ※ なぜ `rate` という命名にするのか？
// `price`は具体的な金額の違いを表す。例: S席=10000円 A席=5000円 の違い
// `rate`は条件や区分に応じて適用される料金というニュアンスになる
// ============================================================

model RateType {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  eventId String

  name         String
  displayOrder Int    @default(0)

  event Event @relation(fields: [eventId], references: [id])

  saleOfferRates SaleOfferRate[]

  @@unique([eventId, name])
}

// ============================================================
// 副券
// ============================================================

model VoucherTemplate {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  eventId String

  name        String
  description String

  event             Event              @relation(fields: [eventId], references: [id])
  saleOfferVouchers SaleOfferVoucher[]
}

// ============================================================
// 販売受付
//
// 例1: 単独公演(SaleOfferEntitlementが1つだけ)
// 一般販売（SaleWindow）
// ├─ S席（SaleOffer）
// │  ├─ 大人・子供 100円（SaleOfferRate）
// │  └─ 公演1・S席在庫への利用権（SaleOfferEntitlement）
// │     └─ 公演1 S席在庫（InventoryPool）
// │        ├─ S席 座席1（InventoryUnit）
// │        ├─ S席 座席2（InventoryUnit）
// │        └─ ...
// └─ A席（SaleOffer）
//    ├─ 大人・子供 30円（SaleOfferRate）
//    └─ 公演1・A席在庫への利用権（SaleOfferEntitlement）
//       └─ 公演1 A席在庫（InventoryPool）
//          ├─ A席 座席1（InventoryUnit）
//          ├─ A席 座席2（InventoryUnit）
//          └─ ...
// 先行販売（SaleWindow）
// ├─ S席（SaleOffer）
// │  ├─ 大人・子供 100円（SaleOfferRate）
// │  └─ 公演1・S席在庫への利用権（SaleOfferEntitlement）
// │     └─ 公演1 S席在庫（InventoryPool）
// │        ├─ S席 座席1（InventoryUnit）
// │        ├─ S席 座席2（InventoryUnit）
// │        └─ ...
// └─ A席（SaleOffer）
//    ├─ 大人・子供 30円（SaleOfferRate）
//    └─ 公演1・A席在庫への利用権（SaleOfferEntitlement）
//       └─ 公演1 A席在庫（InventoryPool）
//          ├─ A席 座席1（InventoryUnit）
//          ├─ A席 座席2（InventoryUnit）
//          └─ ...
//
// 例2: 単独公演 + 料金種別あり
// 一般販売（SaleWindow）
// ├─ S席（SaleOffer）
// │  ├─ 大人 100円（SaleOfferRate）
// │  ├─ 学生 60円（SaleOfferRate）
// │  ├─ 子供 30円（SaleOfferRate）
// │  └─ 公演1・S席在庫への利用権（SaleOfferEntitlement）
// │     └─ 公演1 S席在庫（InventoryPool）
// │        ├─ S席 座席1（InventoryUnit）
// │        ├─ S席 座席2（InventoryUnit）
// │        └─ ...
// │
// └─ A席（SaleOffer）
//    ├─ 大人 50円（SaleOfferRate）
//    ├─ 学生 30円（SaleOfferRate）
//    ├─ 子供 20円（SaleOfferRate）
//    └─ 公演1・A席在庫への利用権（SaleOfferEntitlement）
//       └─ 公演1 A席在庫（InventoryPool）
//          ├─ A席 座席1（InventoryUnit）
//          ├─ A席 座席2（InventoryUnit）
//          └─ ...
//
// 例3: 通し券
// 一般販売（SaleWindow）
// ├─ 2日通し券 S席（SaleOffer）
// │  ├─ 大人・子供 180円（SaleOfferRate）
// │  ├─ 公演1・S席在庫への利用権（SaleOfferEntitlement）
// │  │  └─ 公演1 S席在庫（InventoryPool）
// │  │     ├─ 公演1 S席 座席1（InventoryUnit）
// │  │     ├─ 公演1 S席 座席2（InventoryUnit）
// │  │     └─ ...
// │  └─ 公演2・S席在庫への利用権（SaleOfferEntitlement）
// │     └─ 公演2 S席在庫（InventoryPool）
// │        ├─ 公演2 S席 座席1（InventoryUnit）
// │        ├─ 公演2 S席 座席2（InventoryUnit）
// │        └─ ...
// │
// └─ 2日通し券 A席（SaleOffer）
//    ├─ 大人・子供 90円（SaleOfferRate）
//    ├─ 公演1・A席在庫への利用権（SaleOfferEntitlement）
//    │  └─ 公演1 A席在庫（InventoryPool）
//    │     ├─ 公演1 A席 座席1（InventoryUnit）
//    │     ├─ 公演1 A席 座席2（InventoryUnit）
//    │     └─ ...
//    └─ 公演2・A席在庫への利用権（SaleOfferEntitlement）
//       └─ 公演2 A席在庫（InventoryPool）
//          ├─ 公演2 A席 座席1（InventoryUnit）
//          ├─ 公演2 A席 座席2（InventoryUnit）
//          └─ ...
// ============================================================

model SaleWindow {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  eventId String

  name String

  publishesAt         DateTime? // 公開日時
  applicationStartsAt DateTime // 申し込み開始日時
  applicationEndsAt   DateTime // 申し込み終了日時

  canceledAt   DateTime? // キャンセルした際に値が入る
  cancelReason String? // キャンセルした際に値が入る

  isSmsAuthRequired Boolean // 電話番号認証が必要かどうか？

  method SaleMethod // 販売方式

  // 販売方式が抽選の場合は、以下のカラムに値が入る
  lotteryMode           LotteryMode // 抽選方式
  notifyLotteryResultAt DateTime? // 抽選結果をユーザーに伝える日時

  event Event @relation(fields: [eventId], references: [id])

  saleOffers   SaleOffer[]
  applications Application[]
  feeRules     FeeRule[]
}

// ============================================================
// 販売商品
//
// SaleWindow（先行販売・一般販売など）の中で、ユーザーが実際に選択・購入する商品を表す。
//
// 例: 2日間の公演があり、S席・A席があり、先行販売・一般販売がある場合
// - 先行販売(SaleWindow)
//   - S席 公演1日目（SaleOffer)
//   - S席 公演2日目（SaleOffer)
//   - S席 2日通し券（SaleOffer)
//   - A席 公演1日目（SaleOffer)
//   - A席 公演1日目（SaleOffer)
//   - A席 2日通し券（SaleOffer)
// - 一般販売(SaleWindow)
//   - S席 公演1日目（SaleOffer)
//   - S席 公演2日目（SaleOffer)
//   - S席 2日通し券（SaleOffer)
//   - A席 公演1日目（SaleOffer)
//   - A席 公演1日目（SaleOffer)
//   - A席 2日通し券（SaleOffer)
// ============================================================

model SaleOffer {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  saleWindowId String

  name        String
  description String // 何もない場合は空文字

  maxQuantityPerOrder Int
  displayOrder        Int @default(0)

  saleWindow SaleWindow @relation(fields: [saleWindowId], references: [id])

  saleOfferRates             SaleOfferRate[] // 料金種別がある場合は2つ以上、ない場合は1つだけ紐づく
  saleOfferEntitlements      SaleOfferEntitlement[] // 通し券の場合は2つ以上、その他は1つだけ紐づく
  applicationPreferenceItems ApplicationPreferenceItem[]
  applicationPreferences     ApplicationPreference[]
  saleOfferVouchers          SaleOfferVoucher[]
  feeRules                   FeeRule[]
}

// ============================================================
// 券種
// ============================================================

model SaleOfferRate {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  saleOfferId String
  rateTypeId  String

  price    Int
  currency String @default("JPY")

  minQuantity Int @default(1)
  maxQuantity Int @default(4)

  // 「この商品は2枚単位でしか買えない」というような制約をつけたい場合に使う
  quantityStep Int @default(1)

  displayOrder Int @default(0)

  saleOffer SaleOffer @relation(fields: [saleOfferId], references: [id])
  rateType  RateType  @relation(fields: [rateTypeId], references: [id])

  applicationPreferenceItems ApplicationPreferenceItem[]
  orderItems                 OrderItem[]

  @@unique([saleOfferId, rateTypeId])
}

// ============================================================
// 手数料設定ルール
// ============================================================

model FeeRule {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // eventId は所属 Event を表す。saleWindowId / saleOfferId が NULL の場合は
  // Event 全体の手数料として扱い、saleWindowId がある場合は販売受付単位、
  // saleOfferId がある場合は販売商品単位の手数料として扱う。
  // ただし、「saleWindowId と saleOfferId が両方設定される」「saleOfferId が別イベントに属している」
  // というような不整合が起きないように気をつける必要がある
  eventId      String
  saleWindowId String?
  saleOfferId  String?

  name         String
  displayOrder Int    @default(0)

  // ミスが発覚して無効化した場合、その日時を記録する
  disabledAt DateTime

  payer FeePayer

  currency String @default("JPY")

  // 例1: 5% → rateBasisPoints=500, flatAmount=0
  // 例2: 300円 → rateBasisPoints=0, flatAmount=300
  // 例3: 3% + 100円  → rateBasisPoints=300, flatAmount=100
  rateBasisPoints Int // 割合
  flatAmount      Int // 固定額

  // 最初は切り下げで固定する
  // roundingMode    FeeRoundingMode // 切り上げ / 切り下げ / 四捨五入

  // 以下のような設定をすることも考えられるが必要性が低いので、一旦1チケットごとの扱いにする
  // - PER_TICKET: 1チケットごと
  // - PER_ORDER: 1注文ごと

  event      Event       @relation(fields: [eventId], references: [id])
  saleWindow SaleWindow? @relation(fields: [saleWindowId], references: [id])
  saleOffer  SaleOffer?  @relation(fields: [saleOfferId], references: [id])

  orderFeeLines OrderFeeLine[]
}

// ============================================================
// 販売商品が付与する公演利用権
//
// Entitlement=利用権
//
// 通常券では 1 saleOffer に対して1件。
// 通し券では 1 saleOffer に対して複数件。
// ============================================================

model SaleOfferEntitlement {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  saleOfferId     String
  inventoryPoolId String

  saleOffer     SaleOffer     @relation(fields: [saleOfferId], references: [id])
  inventoryPool InventoryPool @relation(fields: [inventoryPoolId], references: [id])

  ticketEntitlements TicketEntitlement[]
  performance        Performance?        @relation(fields: [performanceId], references: [id])
  performanceId      String?
}

model SaleOfferVoucher {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  saleOfferId       String
  voucherTemplateId String

  saleOffer       SaleOffer       @relation(fields: [saleOfferId], references: [id])
  voucherTemplate VoucherTemplate @relation(fields: [voucherTemplateId], references: [id])

  @@unique([saleOfferId, voucherTemplateId])
}

// ============================================================
// 在庫
//
// InventoryPool: 公演 x 席種に対して 1 レコード作成される
// InventoryUnit: 販売・確保・発券で消費される最小単位。指定席でも整理番号でも、発券時には必ず1つのInventoryUnitを消費する。
// ============================================================

model InventoryPool {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  performanceId  String
  seatCategoryId String

  admissionMethod      AdmissionMethod
  seatAllocationMethod SeatAllocationMethod

  capacity  Int
  heldCount Int @default(0)
  soldCount Int @default(0)

  performance  Performance  @relation(fields: [performanceId], references: [id])
  seatCategory SeatCategory @relation(fields: [seatCategoryId], references: [id])

  units             InventoryUnit[]
  offerEntitlements SaleOfferEntitlement[]
  holds             InventoryHold[]

  @@unique([performanceId, seatCategoryId])
}

model InventoryUnit {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  inventoryPoolId String // 1 inventoryUnit は 1inventoryPool にのみ所属できるようにする
  seatId          String? // 指定席方式の場合だけ値が入る。整理番号方式では値が入らない

  entryNumber Int? // 整理番号方式の場合だけ値が入る。指定席方式の場合は値が入らない
  status      InventoryUnitStatus @default(AVAILABLE)

  inventoryPool InventoryPool @relation(fields: [inventoryPoolId], references: [id])
  seat          Seat?         @relation(fields: [seatId], references: [id])

  ticketEntitlements TicketEntitlement[]
  inventoryHoldItems InventoryHoldItem[]
  performance        Performance?        @relation(fields: [performanceId], references: [id])
  performanceId      String?

  @@unique([inventoryPoolId, entryNumber])
}

// ============================================================
// 在庫の一時確保
//
// 先着販売などで在庫を一時的に仮押さえする際に使う。
// InventoryHoldItemは現在確保中のInventoryUnitを表す。
// 解放・期限切れ時はInventoryUnit.statusを戻し、対応するHoldItemを削除する。
//
// ticketmaster にも同様の概念が存在する
// @see https://developer.ticketmaster.com/products-and-docs/apis/partner/
// ============================================================

model InventoryHold {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  userId      String
  orderItemId String? @unique

  quantity Int

  status    InventoryHoldStatus @default(ACTIVE)
  expiresAt DateTime

  user      User       @relation(fields: [userId], references: [id])
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id])

  items           InventoryHoldItem[]
  inventoryPool   InventoryPool?      @relation(fields: [inventoryPoolId], references: [id])
  inventoryPoolId String?
}

model InventoryHoldItem {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  inventoryHoldId String
  inventoryUnitId String @unique

  inventoryHold InventoryHold @relation(fields: [inventoryHoldId], references: [id])
  inventoryUnit InventoryUnit @relation(fields: [inventoryUnitId], references: [id])
  performance   Performance?  @relation(fields: [performanceId], references: [id])
  performanceId String?
}

// ============================================================
// 例1: 希望制なしの単独応募
//
// Application
// └─ 第1希望: 9/2 S席
//    ├─ 大人 × 2
//    └─ 子供 × 1
//
// ※ 希望制でない場合も ApplicationPreference は1件作成される
//
// 例2: 希望制ありの応募
//
// Application
// ├─ 第1希望: 9/1 S席
// │  ├─ 大人 × 2
// │  └─ 子供 × 1
// ├─ 第2希望: 9/1 A席
// │  ├─ 大人 × 2
// │  └─ 子供 × 1
// └─ 第3希望: 9/2 S席
//    ├─ 大人 × 2
//    └─ 子供 × 1
// ============================================================

model Application {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  userId       String
  saleWindowId String // 正規化の観点では冗長だが、対応関係のわかりやすさのために持たせる

  status ApplicationStatus @default(APPLIED)

  user       User       @relation(fields: [userId], references: [id])
  saleWindow SaleWindow @relation(fields: [saleWindowId], references: [id])

  applicationPreferences ApplicationPreference[]
}

model ApplicationPreference {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  applicationId String
  saleOfferId   String // 正規化の観点では冗長だが、対応関係のわかりやすさのために持たせる

  preferenceRank Int // 第1希望→1 第2希望→2 第3希望→3

  lotteryResult LotteryResult @default(PENDING)

  application Application @relation(fields: [applicationId], references: [id])
  saleOffer   SaleOffer   @relation(fields: [saleOfferId], references: [id])

  applicationPreferenceItems ApplicationPreferenceItem[]

  @@unique([applicationId, preferenceRank])
}

model ApplicationPreferenceItem {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  applicationPreferenceId String
  saleOfferRateId         String

  quantity Int

  applicationPreference ApplicationPreference @relation(fields: [applicationPreferenceId], references: [id])
  saleOfferRate         SaleOfferRate         @relation(fields: [saleOfferRateId], references: [id])

  orderItem   OrderItem?
  saleOffer   SaleOffer? @relation(fields: [saleOfferId], references: [id])
  saleOfferId String?

  @@unique([applicationPreferenceId, saleOfferRateId])
}

// ============================================================
// 注文・決済・返金
//
// Application は「欲しいです」という意思表示に過ぎない。
// Order は「買います/買いました」という取引を表現する
//
// 抽選ではない先着販売の場合は、Application のデータは作成されない
// ============================================================

model Order {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  userId String

  status OrderStatus @default(PENDING)

  subtotalAmount     Int
  feeAmount          Int    @default(0)
  buyerFeeAmount     Int    @default(0)
  organizerFeeAmount Int    @default(0)
  totalAmount        Int
  currency           String @default("JPY")

  user User @relation(fields: [userId], references: [id])

  orderItems    OrderItem[]
  orderFeeLines OrderFeeLine[]
  payments      Payment[]
  refunds       Refund[]
}

model OrderItem {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  orderId                     String
  saleOfferRateId             String
  applicationPreferenceItemId String? @unique // 抽選の場合だけ値が入る

  quantity  Int
  unitPrice Int

  order         Order         @relation(fields: [orderId], references: [id])
  saleOfferRate SaleOfferRate @relation(fields: [saleOfferRateId], references: [id])

  applicationPreferenceItem ApplicationPreferenceItem? @relation(fields: [applicationPreferenceItemId], references: [id])

  tickets       Ticket[]
  inventoryHold InventoryHold?
  refundItems   RefundItem[]
  orderFeeLines OrderFeeLine[]
}

// ============================================================
// 注文時に適用された手数料明細
//
// 注文後に FeeRule が変更されても購入者請求・主催者精算・返金判断を
// 監査できるように、計算条件と計算結果をスナップショットとして保持する。
// ============================================================

model OrderFeeLine {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  orderId     String
  orderItemId String
  feeRuleId   String

  name         String
  displayOrder Int

  payer FeePayer

  rateBasisPoints Int // 割合
  flatAmount      Int // 固定額

  currency       String
  unitBaseAmount Int // 1チケットあたりの割合計算対象金額
  quantity       Int // 手数料が適用される枚数

  // orderItem に対して実際に適用される手数料金額
  // (Math.floor(unitBaseAmount * rateBasisPoints / 10000) + flatAmount) * quantity
  feeAmount Int

  order     Order     @relation(fields: [orderId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  feeRule   FeeRule?  @relation(fields: [feeRuleId], references: [id])

  @@index([orderId])
  @@index([orderItemId])
  @@index([feeRuleId])
}

// order : payment = 1 : N
// 決済が1回失敗して再試行したら成功したという場合は、1 order に対して 複数 payment が作成される
model Payment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  orderId String

  provider          String
  providerPaymentId String

  amount   Int
  currency String        @default("JPY")
  status   PaymentStatus @default(PENDING)

  order   Order    @relation(fields: [orderId], references: [id])
  refunds Refund[]

  @@unique([provider, providerPaymentId])
}

model Refund {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  orderId   String
  paymentId String @unique

  providerRefundId String? @unique

  amount   Int
  currency String       @default("JPY")
  status   RefundStatus @default(PENDING)
  reason   String

  completedAt DateTime?

  order   Order        @relation(fields: [orderId], references: [id])
  payment Payment      @relation(fields: [paymentId], references: [id])
  items   RefundItem[]
}

model RefundItem {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  refundId    String
  orderItemId String

  quantity Int
  amount   Int

  refund    Refund    @relation(fields: [refundId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@unique([refundId, orderItemId])
}

// ============================================================
// 発券済みチケット
// ============================================================

model Ticket {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  orderItemId String
  ownerUserId String

  status TicketStatus @default(ACTIVE)

  serialNumber String @unique
  qrToken      String @unique

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  owner     User      @relation(fields: [ownerUserId], references: [id])

  ticketEntitlements TicketEntitlement[]
  ticketVouchers     TicketVoucher[]

  @@index([orderItemId])
  @@index([ownerUserId, status])
}

// ============================================================
// チケットの公演利用権
//
// 通常券なら1件。
// 通し券なら公演数分作成される。
// ============================================================

model TicketEntitlement {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  ticketId               String
  performanceId          String
  saleOfferEntitlementId String
  inventoryUnitId        String @unique

  usedAt DateTime?

  ticket               Ticket               @relation(fields: [ticketId], references: [id])
  performance          Performance          @relation(fields: [performanceId], references: [id])
  saleOfferEntitlement SaleOfferEntitlement @relation(fields: [saleOfferEntitlementId], references: [id])
  inventoryUnit        InventoryUnit        @relation(fields: [inventoryUnitId], references: [id])

  @@unique([ticketId, performanceId])
}

// ============================================================
// 発行済み副券
// ============================================================

model TicketVoucher {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  ticketId String

  name   String
  usedAt DateTime

  ticket Ticket @relation(fields: [ticketId], references: [id])
}
