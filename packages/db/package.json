{
  "name": "@ticket-app/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "bun --env-file=../../apps/server/.env prisma db push",
    "db:generate": "bun prisma generate",
    "db:studio": "bun --env-file=../../apps/server/.env prisma studio",
    "db:migrate": "bun --env-file=../../apps/server/.env prisma migrate dev"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@ticket-app/env": "workspace:*"
  },
  "devDependencies": {
    "@ticket-app/config": "workspace:*",
    "prisma": "7.8.0",
    "typescript": "catalog:"
  }
}
