{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun --env-file=.env --watch src/index.ts",
    "start": "node dist/index.mjs"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@ticket-app/api": "workspace:*",
    "@ticket-app/auth": "workspace:*",
    "@ticket-app/db": "workspace:*",
    "@ticket-app/env": "workspace:*",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@ticket-app/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.22.3",
    "typescript": "catalog:"
  },
  "trustedDependencies": [
    "supabase"
  ]
}
